// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String?
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  // Relations
  sentRelationships     Relationship[] @relation("User1")
  receivedRelationships Relationship[] @relation("User2")

  vaultItems SecretVault[]

  userProfileAI UserProfileAI?

  recommendationLogs RecommendationLog[]
}

model Relationship {
  id        Int      @id @default(autoincrement())

  user1Id   Int
  user2Id   Int

  requestedById Int

  status    RelationshipStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user1 User @relation("User1", fields: [user1Id], references: [id])
  user2 User @relation("User2", fields: [user2Id], references: [id])

  @@unique([user1Id, user2Id]) // avoid duplicate
  @@index([user1Id])
  @@index([user2Id])
}

enum RelationshipStatus {
  PENDING
  CONNECTED
  REJECTED
}

model SecretVault {
  id        Int      @id @default(autoincrement())

  ownerId   Int
  itemType  String
  content   String

  isVisibleToPartner Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner User @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([itemType])
}

model UserProfileAI {
  userId Int @id

  tags             String[]   // Normalized interests
  preferenceScore  Json       // { "food": 0.9, "travel": 0.7 }

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Vendor {
  id         Int     @id @default(autoincrement())
  name       String
  category   String
  priceRange String
  location   String

  products Product[]
}

model Product {
  id        Int     @id @default(autoincrement())

  vendorId  Int
  name      String
  category  String
  price     Float

  tags      String[]

  createdAt DateTime @default(now())

  // Relations
  vendor Vendor @relation(fields: [vendorId], references: [id])

  recommendationLogs RecommendationLog[]

  @@index([vendorId])
  @@index([category])
  @@index([tags], type: Gin)
}

model RecommendationLog {
  id        Int      @id @default(autoincrement())

  userId    Int
  productId Int

  score     Float
  source    RecommendationSource

  context   Json?    // { "reason": "matched_food", "event": "valentine" }
  isClicked Boolean  @default(false)
  isPurchased Boolean @default(false)

  createdAt DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([productId])
  @@index([source])
}

enum RecommendationSource {
  VAULT
  AI
  BEHAVIOR
  TRENDING
  SURPRISE
}